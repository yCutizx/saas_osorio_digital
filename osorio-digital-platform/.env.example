# Supabase — copie este arquivo para .env.local e preencha com suas credenciais
# Encontre esses valores em: https://supabase.com/dashboard > seu projeto > Project Settings > API

NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key_aqui

# Service Role Key — NUNCA exponha no frontend (sem NEXT_PUBLIC_)
# Supabase Dashboard > Project Settings > API > service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui

# Meta Ads (Marketing API) — integração da Etapa 11
# Long-lived token (60 dias) do perfil pessoal com acesso às Ad Accounts dos clientes
META_ACCESS_TOKEN=
# Versão da Graph API (default v21.0 se vazio)
META_API_VERSION=v21.0
# Secret pra autenticar o cron Vercel (gerar com `openssl rand -hex 32` ou UUID)
META_CRON_SECRET=

# Etapa 15 — Módulo Financeiro
# Número do WhatsApp do Rafael (E.164 sem +) — usado no botão "Quero regularizar"
# do dashboard do cliente (/client/finance) quando há fatura atrasada.
RAFAEL_WHATSAPP_NUMBER=5511999999999
